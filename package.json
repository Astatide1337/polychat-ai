{
  "name": "polychat-ai",
  "version": "0.1.3",
  "description": "Self-hosted browser-backed AI CLI and local OpenAI-compatible API server.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "polychat": "dist/index.js"
  },
  "files": [
    "dist",
    "bin",
    "web-dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "cli",
    "openai-compatible",
    "browser",
    "claude",
    "chatgpt",
    "deepseek",
    "gemini",
    "kimi"
  ],
  "author": "Astatide1337",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Astatide1337/polychat-ai.git"
  },
  "bugs": {
    "url": "https://github.com/Astatide1337/polychat-ai/issues"
  },
  "homepage": "https://github.com/Astatide1337/polychat-ai#readme",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "cargo build --release --manifest-path rust/Cargo.toml",
    "build:history": "npm --workspace packages/history-core run build",
    "build:mcp": "npm --workspace apps/mcp run build",
    "build:extension": "npm --workspace apps/extension run build",
    "build:workspaces": "npm run build:history && npm run build:mcp && npm run build:extension",
    "dev": "tsup --watch",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:mcp": "npm --workspace apps/mcp run dev",
    "dev:extension": "npm --workspace apps/extension run dev",
    "start": "node dist/index.js",
    "test": "node --test test/**/*.test.mjs",
    "test:web": "vitest run --config web/vitest.config.ts",
    "test:history": "npm --workspace packages/history-core run test",
    "test:workspaces": "npm run test:history && npm --workspace apps/mcp run test",
    "verify": "npm run build && npm run build:web && npm run build:workspaces && npm run test && npm run test:web && npm run test:workspaces",
    "test:e2e": "playwright test",
    "test:live:web": "node scripts/live-webui-e2e.mjs",
    "conformance:report": "node scripts/conformance-report.mjs",
    "stage:binary": "node scripts/stage-binary.mjs",
    "stage:binary:all": "node scripts/stage-binary.mjs --all",
    "verify:package": "node scripts/verify-package.mjs",
    "verify:package:all": "node scripts/verify-package.mjs --all",
    "prepack": "npm run build && npm run build:web && npm run build:workspaces && npm run build:server && npm run stage:binary && npm run verify:package",
    "prepublishOnly": "npm run verify && npm run verify:package:all",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "default-browser": "^5.5.0",
    "get-browser-path": "^1.1.0",
    "ink": "^7.0.2",
    "ink-text-input": "^6.0.0",
    "lucide-react": "^1.21.0",
    "node-sqlite3-wasm": "^0.8.0",
    "ora": "^9.4.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
