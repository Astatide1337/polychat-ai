# Polychat local secrets. Do not share this file.
# Copy to ~/.polychat/.env or it will be generated by `polychat init`.
# This file is NOT tracked by git.

# === Required ===

# Encryption key for session files. Generate with: openssl rand -hex 32
# Must be at least 32 characters (64 hex chars).
POLYCHAT_SECRET_KEY=

# === Optional ===

# Bearer token required by API clients. If unset, the API has no auth.
POLYCHAT_API_KEY=

# Override browser detection (chrome or firefox)
POLYCHAT_BROWSER=

# Full path to browser binary (overrides auto-detection)
POLYCHAT_BROWSER_PATH=

# Full path to polychat-server binary (overrides bundled/auto-detected)
POLYCHAT_SERVER_BINARY=

# Override the server URL used by CLI commands (default: http://127.0.0.1:1443)
POLYCHAT_SERVER_URL=

# === Testing (E2E test conversation IDs) ===

POLYCHAT_TEST_DEEPSEEK_CONVERSATION_ID=
POLYCHAT_TEST_CLAUDE_CONVERSATION_ID=
POLYCHAT_TEST_CHATGPT_CONVERSATION_ID=
POLYCHAT_TEST_KIMI_CONVERSATION_ID=
